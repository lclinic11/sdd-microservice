# SDD Microservice - 环境变量配置
# 复制此文件为 .env 并修改对应值
# 注意：.env 已加入 .gitignore，不要提交到版本控制

# ============================
# 数据库配置
# ============================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sdd_user
DB_USERNAME=root
DB_PASSWORD=root

# ============================
# Redis 配置
# ============================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================
# Nacos 配置
# ============================
NACOS_SERVER_ADDR=localhost:8848
NACOS_NAMESPACE=public

# ============================
# JWT 安全配置
# 生产环境请替换为强随机密钥（至少 32 字符）
# 生成命令：openssl rand -base64 48
# ============================
JWT_SECRET=sdd-microservice-jwt-secret-key-minimum-32-chars-please-change-in-prod
