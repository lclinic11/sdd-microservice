# SDD Microservice - 环境变量配置
# 1. 复制此文件：cp .env.example .env
# 2. 按需修改 .env 中的值
# 注意：.env 已加入 .gitignore，永远不要提交到版本控制！

# ============================
# MySQL 配置
# ============================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sdd_user
DB_USERNAME=root
# 请修改为强密码
MYSQL_ROOT_PASSWORD=root123

# ============================
# Redis 配置（密码与 scripts/redis.conf 中一致）
# ============================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=sdd123

# ============================
# Nacos 配置
# ============================
NACOS_SERVER_ADDR=localhost:8848
NACOS_NAMESPACE=public
NACOS_PORT=8848
# Nacos 认证 Token（生产环境必须修改，至少 32 字符）
NACOS_AUTH_TOKEN=SecretKey012345678901234567890123456789012345678901234567890123456789
NACOS_AUTH_IDENTITY_KEY=serverIdentity
NACOS_AUTH_IDENTITY_VALUE=security

# ============================
# JWT 安全配置
# 生产环境必须替换为强随机密钥（至少 32 字符）
# 生成命令：openssl rand -base64 48
# ============================
JWT_SECRET=sdd-microservice-jwt-secret-key-change-in-production-environment
